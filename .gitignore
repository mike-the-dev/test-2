# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code local agent state (per-machine, not for version control)
.claude/

# playwright MCP artifacts (screenshots, console dumps, snapshots).
# Future screenshots should be written under .playwright-mcp/ or /tmp/ so
# they stay out of the repo-root file tree entirely; the anchored /*.png
# rule below is belt-and-suspenders for anything that slips through.
.playwright-mcp/
/*.png

# transient hero-ui reference project (checked in locally during M3 UI refactor)
.hero-project-chat-ui/
